{
  "name": "nordhjem-medusa",
  "version": "0.0.1",
  "description": "NordHjem e-commerce backend powered by Medusa v2",
  "author": "NordHjem",
  "license": "MIT",
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepare": "husky"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@mikro-orm/postgresql": "6.4.16",
    "resend": "^6.9.3",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "prettier": "^3.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.0",
    "ajv": "^8.13.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^20.4.4"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@mikro-orm/core": "6.4.16",
    "@mikro-orm/knex": "6.4.16",
    "@mikro-orm/migrations": "6.4.16",
    "@mikro-orm/postgresql": "6.4.16",
    "@mikro-orm/cli": "6.4.16"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
